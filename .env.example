# Engram configuration (copy to .env and fill in)

# BYOK: set a key for ANY ONE provider below. Engram picks the first key it
# finds (in this order), or you can force one with ENGRAM_PROVIDER.
# Several providers have a genuinely free API key — marked (free).

# --- free options ---
GROQ_API_KEY=                 # https://console.groq.com  (free, fast)
GEMINI_API_KEY=               # https://aistudio.google.com/apikey  (free tier)
OPENROUTER_API_KEY=           # https://openrouter.ai/keys  (has ":free" models)

# --- paid options ---
ANTHROPIC_API_KEY=            # https://console.anthropic.com  (Claude)
OPENAI_API_KEY=               # https://platform.openai.com  (ChatGPT)

# --- local option (no key, fully private) ---
# Run Ollama locally (https://ollama.com, e.g. `ollama pull llama3.1`) and set
# ENGRAM_PROVIDER=ollama below. Conversations are summarized on your machine.

# Force which provider to use: anthropic | openai | groq | gemini | openrouter | ollama.
# Leave empty to auto-pick the first provider whose key is set above.
ENGRAM_PROVIDER=

# Override the model. Leave empty to use the provider's default
# (groq: llama-3.3-70b-versatile, gemini: gemini-2.0-flash,
#  openrouter: meta-llama/llama-3.3-70b-instruct:free,
#  anthropic: claude-sonnet-4-6, openai: gpt-4o-mini).
ENGRAM_MODEL=

# Where the knowledge base is written (the folder that gets synced to Git/Drive).
ENGRAM_KB_DIR=./kb

# Optional: rclone remote name for Google Drive mirroring (e.g. "gdrive").
# Leave empty to skip Drive sync. Set up with: rclone config
ENGRAM_DRIVE_REMOTE=
ENGRAM_DRIVE_PATH=engram-kb
