# Engram configuration (copy to .env and fill in)

# BYOK: your own Anthropic API key, used for the summarize step.
ANTHROPIC_API_KEY=sk-ant-...

# Model used to summarize conversations into KB entries.
ENGRAM_MODEL=claude-sonnet-4-6

# Where the knowledge base is written (the folder that gets synced to Git/Drive).
ENGRAM_KB_DIR=./kb

# Optional: rclone remote name for Google Drive mirroring (e.g. "gdrive").
# Leave empty to skip Drive sync. Set up with: rclone config
ENGRAM_DRIVE_REMOTE=
ENGRAM_DRIVE_PATH=engram-kb
