{
  "name": "engram-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Engram — your AI conversations, remembered. Capture, summarize, and own your LLM chats as a portable knowledge base.",
  "license": "MIT",
  "author": "Sufian Abu",
  "repository": { "type": "git", "url": "https://github.com/Sufian-Abu/engram.git" },
  "homepage": "https://github.com/Sufian-Abu/engram#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "start": "tsx packages/cli/src/index.ts serve",
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest": "tsx packages/cli/src/index.ts ingest",
    "sync": "tsx packages/cli/src/index.ts sync",
    "engram": "tsx packages/cli/src/index.ts",
    "serve": "tsx packages/cli/src/index.ts serve",
    "proxy": "tsx packages/proxy/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
